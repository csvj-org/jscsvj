{
  "name": "jscsvj",
  "version": "0.0.0",
  "description": "JavaScript / TypeScript reader and writer for CSVJ files",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "keywords": [
    "csvj",
    "csv",
    "json",
    "parser",
    "serializer"
  ],
  "license": "MIT",
  "homepage": "https://csvj.org",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/csvj-org/jscsvj.git"
  },
  "bugs": {
    "url": "https://github.com/csvj-org/jscsvj/issues"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^4.1.7"
  }
}
